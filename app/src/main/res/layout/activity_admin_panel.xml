<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".AdminPanelActivity">
    <Space
        android:layout_width="match_parent"
        android:layout_height="16dp"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Admin Panel 🔑"
        android:textSize="32sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText"
        />
    <Space
        android:layout_width="match_parent"
        android:layout_height="16dp"
        />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#ccc"
        app:cardElevation="5dp"
        app:cardCornerRadius="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <EditText
                android:id="@+id/sneakerModelEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:hint="Model buta"
                android:importantForAutofill="no"
                tools:ignore="HardcodedText"
                android:inputType="text" />
            <EditText
                android:id="@+id/sneakerBrandEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:hint="Marka buta"
                android:importantForAutofill="no"
                tools:ignore="HardcodedText"
                android:inputType="text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="100">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="85"
                    android:orientation="vertical">
                    <EditText
                        android:id="@+id/sneakerReleaseYearEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Rok wydania"
                        android:importantForAutofill="no"
                        tools:ignore="HardcodedText"
                        android:inputType="number" />
                    <EditText
                        android:id="@+id/sneakerPriceEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Cena"
                        android:importantForAutofill="no"
                        tools:ignore="HardcodedText"
                        android:inputType="numberDecimal" />
                </LinearLayout>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="11"
                    />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:weightSum="10">

                    <Button
                        android:id="@+id/addToDatabaseButton"
                        android:layout_width="112dp"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center"
                        android:text="Dodaj do bazy"
                        tools:ignore="HardcodedText"
                        android:textSize="16sp"
                        android:background="@drawable/button_square" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <Space
        android:layout_width="match_parent"
        android:layout_height="35dp" />
    <ListView
        android:id="@+id/sneakersAdminListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@android:color/transparent"
        android:dividerHeight="10sp"
        />
</LinearLayout>